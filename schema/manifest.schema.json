{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Geoffe-Ga/aptitude-course/schema/manifest.schema.json",
  "title": "APTITUDE course content manifest",
  "description": "Machine-readable index of the course corpus, generated from per-file YAML frontmatter by scripts/build_manifest.py. This is the contract the Adepthood app consumes (see CONTENT_FORMAT.md and adepthood#389). Changing it requires a schema_version bump (see CONSUMPTION.md).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "chapters", "site_resources"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Semver of this manifest contract. Coordinated with adepthood#389.",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "chapters": {
      "type": "array",
      "items": { "$ref": "#/$defs/chapter" }
    },
    "site_resources": {
      "type": "array",
      "items": { "$ref": "#/$defs/site_resource" }
    }
  },
  "$defs": {
    "chapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "stage", "chapter", "order", "slug",
        "title", "content_type", "release_day", "media", "path"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "stage": { "type": "integer", "minimum": 1, "maximum": 10 },
        "chapter": { "type": "integer", "minimum": 1 },
        "order": { "type": "integer", "minimum": 1 },
        "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "title": { "type": "string", "minLength": 1 },
        "content_type": {
          "type": "string",
          "enum": ["chapter", "essay", "prompt", "video"]
        },
        "release_day": { "type": "integer", "minimum": 0 },
        "summary": { "type": "string" },
        "media": {
          "type": "array",
          "items": { "$ref": "#/$defs/media_item" }
        },
        "path": {
          "type": "string",
          "pattern": "^markdown/.+\\.md$"
        }
      }
    },
    "site_resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "title", "path"],
      "properties": {
        "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "media": {
          "type": "array",
          "items": { "$ref": "#/$defs/media_item" }
        },
        "path": {
          "type": "string",
          "pattern": "^markdown/.+\\.md$"
        }
      }
    },
    "media_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["video", "image", "audio"] },
        "url": { "type": "string" },
        "path": { "type": "string" },
        "poster": { "type": "string" },
        "caption": { "type": "string" }
      },
      "anyOf": [
        { "required": ["url"] },
        { "required": ["path"] }
      ]
    }
  }
}
